# ==========================================
# WareFlow Frontend Environment
# ==========================================

# ------------------------------------------
# Development thủ công
# ------------------------------------------
# Vite dev server dùng biến này để proxy /api sang backend local.
# Biến này chỉ được đọc bởi Vite dev server, không expose vào browser.
BACKEND_URL=http://localhost:3000

# ------------------------------------------
# Development bằng Docker Compose
# ------------------------------------------
# Khi chạy qua docker-compose.yml ở thư mục gốc, compose sẽ override:
# BACKEND_URL=http://backend:3000
# Không cần tự đổi file này nếu chạy bằng docker compose.

# ------------------------------------------
# Production
# ------------------------------------------
# Để trống khi frontend được phục vụ cùng domain với reverse proxy /api.
# Ví dụ production compose hiện tại dùng nginx để route:
#   WEB_DOMAIN/      -> frontend
#   WEB_DOMAIN/api/* -> backend
VITE_API_URL=

# Chỉ set khi deploy frontend standalone khác domain backend.
# Ví dụ:
# VITE_API_URL=https://api.example.com

# Port Nginx bên trong frontend production container.
# production-compose.yml có thể override giá trị này.
FRONTEND_PORT=80
