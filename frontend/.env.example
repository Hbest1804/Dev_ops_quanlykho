# Backend API URL (dùng cho Vite proxy khi dev local)
BACKEND_URL=http://localhost:3000

# URL backend khi deploy production (Vercel, Railway, ...)
# Để trống khi chạy local — frontend sẽ dùng Vite proxy
VITE_API_URL=

# Cấu hình Supabase (nếu dùng Supabase Client trực tiếp trên frontend)
# VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhb...
