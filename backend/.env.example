PORT=3000
CORS_ORIGIN=http://localhost:5173

# Supabase Postgres Database Configuration
# Lấy thông tin này ở phần Database Settings > Connection String trong project Supabase
POSTGRES_HOST=aws-0-ap-southeast-1.pooler.supabase.com
POSTGRES_PORT=6543
POSTGRES_DB=postgres
POSTGRES_USER=postgres.xxxxxxxxxxxxxxxxxx
POSTGRES_PASSWORD=your-supabase-db-password

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key

# Admin Seed Data
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-admin-password
ADMIN_NAME=Administrator