# =============================================================
# SERVER
# =============================================================
PORT=3000
NODE_ENV=development   # production khi deploy

# =============================================================
# CORS — cho phép frontend gọi API
# Local:      http://localhost:5173
# Production: https://your-frontend.vercel.app
# Nhiều origin: https://your-frontend.vercel.app,http://localhost:5173
# =============================================================
CORS_ORIGIN=http://localhost:5173

# =============================================================
# VERCEL SERVERLESS FLAG
# Đặt thành 1 khi deploy lên Vercel (tự động được Vercel set)
# Để trống hoặc xóa khi chạy local
# =============================================================
VERCEL=

# =============================================================
# SUPABASE POSTGRES
# Lấy thông tin tại: Supabase Dashboard > Project Settings
#                    > Database > Connection string (Transaction mode)
# =============================================================
POSTGRES_HOST=aws-0-ap-southeast-1.pooler.supabase.com
POSTGRES_PORT=6543
POSTGRES_DB=postgres
POSTGRES_USER=postgres.xxxxxxxxxxxxxxxxxx
POSTGRES_PASSWORD=your-supabase-db-password

# =============================================================
# JWT AUTHENTICATION
# Dùng chuỗi ngẫu nhiên dài >= 64 ký tự
# Tạo nhanh: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# =============================================================
JWT_SECRET=your-super-secret-jwt-key-min-64-chars

# =============================================================
# ADMIN SEED DATA — tài khoản admin được tạo tự động khi khởi động
# =============================================================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-admin-password
ADMIN_NAME=Administrator
