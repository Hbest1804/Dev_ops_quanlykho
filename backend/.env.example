# ==========================================
# CẤU HÌNH BACKEND
# ==========================================

# Cổng lắng nghe và chế độ môi trường
PORT=3000
NODE_ENV=development

# --- CORS ---
# Domain Frontend được phép gọi API (ngăn cách bằng dấu phẩy nếu có nhiều)
CORS_ORIGIN=http://localhost:5173

# --- DATABASE / SUPABASE ---
# Khuyến nghị dùng cổng pooler 6543 (Transaction mode)
POSTGRES_HOST=aws-0-ap-southeast-1.pooler.supabase.com
POSTGRES_PORT=6543
POSTGRES_DB=postgres
POSTGRES_USER=postgres.xxxxxxxxxxxxxxxxxx
POSTGRES_PASSWORD=your-supabase-db-password

# --- BẢO MẬT JWT ---
# Khóa bí mật ký JWT (Đổi thành chuỗi ngẫu nhiên >= 64 ký tự)
JWT_SECRET=your-super-secret-jwt-key-min-64-chars

# --- TÀI KHOẢN ADMIN MẶC ĐỊNH ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-admin-password
ADMIN_NAME=Administrator
