# ==========================================
# WareFlow Backend Environment
# ==========================================

# ------------------------------------------
# Runtime
# ------------------------------------------
# development: chạy local/manual, error response có stack trace, DB không dùng SSL.
# production: cookie refresh dùng Secure + SameSite=None, DB bật SSL.
NODE_ENV=development
PORT=3000

# Set VERCEL=1 nếu deploy backend dạng serverless trên Vercel.
# Khi bật, app sẽ export Express app và không tự app.listen().
# VERCEL=1

# ------------------------------------------
# CORS
# ------------------------------------------
# Danh sách origin frontend được phép gọi API, ngăn cách bằng dấu phẩy.
# Dev thủ công:
CORS_ORIGIN=http://localhost:5173

# Docker dev thường vẫn truy cập frontend qua browser ở localhost:5173.
# Production ví dụ:
# CORS_ORIGIN=https://your-web-domain.com
# Nhiều origin:
# CORS_ORIGIN=https://your-web-domain.com,https://admin.your-web-domain.com

# ------------------------------------------
# Database - development thủ công
# ------------------------------------------
# Nếu chạy PostgreSQL local:
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-database-password

# ------------------------------------------
# Database - Docker Compose development
# ------------------------------------------
# Khi chạy qua docker-compose.yml ở thư mục gốc, compose sẽ override:
# POSTGRES_HOST=db
# POSTGRES_PORT=5432
# POSTGRES_DB=${POSTGRES_DB}
# POSTGRES_USER=${POSTGRES_USER}
# POSTGRES_PASSWORD=${POSTGRES_PASSWORD}

# ------------------------------------------
# Database - production / Supabase
# ------------------------------------------
# Khi NODE_ENV=production, backend sẽ bật SSL cho pg Pool.
# Supabase thường dùng pooler port 6543.
# POSTGRES_HOST=aws-0-ap-southeast-1.pooler.supabase.com
# POSTGRES_PORT=6543
# POSTGRES_DB=postgres
# POSTGRES_USER=postgres.xxxxxxxxxxxxxxxxxx
# POSTGRES_PASSWORD=your-supabase-db-password

# ------------------------------------------
# Security
# ------------------------------------------
# Dùng chuỗi bí mật dài, ngẫu nhiên và không commit secret thật.
JWT_SECRET=your-super-secret-jwt-key-min-64-chars

# ------------------------------------------
# Default admin seed
# ------------------------------------------
# Backend sẽ tạo admin mặc định khi khởi động nếu database chưa có user role admin.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-admin-password
ADMIN_NAME=Administrator
