NODE_ENV=development

# --- DATABASE CONFIGURATION ---
# Nếu bạn dùng Supabase thay vì PostgreSQL local, hãy điền thông tin kết nối Supabase vào đây.
# (Lưu ý: trong file docker-compose.yml hiện tại đang fix cứng POSTGRES_HOST: db. 
# Để dùng được host ngoài như Supabase khi chạy bằng Docker, bạn cần sửa dòng đó thành POSTGRES_HOST: ${POSTGRES_HOST:-db} và mở comment dòng dưới)
# POSTGRES_HOST=aws-0-ap-southeast-1.pooler.supabase.com
POSTGRES_DB=postgres
POSTGRES_USER=postgres.xxxxxxxxxxxxxxxxxx
POSTGRES_PASSWORD=your-database-password
POSTGRES_PORT=6543

# --- ADMIN SEED DATA ---
# Tài khoản admin mặc định được tạo ra khi hệ thống khởi tạo database
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-admin-password
ADMIN_NAME=Administrator

# --- SECURITY ---
# Chuỗi bí mật dùng để mã hóa JWT, hãy đổi thành chuỗi ngẫu nhiên dài khi đưa lên production
JWT_SECRET=your-super-secret-jwt-key-replace-me

# --- PORTS ---
# Port chạy cho backend và frontend trong Docker
BACKEND_PORT=3000
FRONTEND_PORT=5173

# --- PRODUCTION CONFIG ---
# Khi triển khai lên production, bạn có thể cần cấu hình thêm các biến môi trường như
BACKEND_HOST=your-production-backend-domain.com
FRONTEND_HOST=your-production-frontend-domain.com
FRONTEND_PORT=80
NGINX_PORT=80
API_DOMAIN=?
WEB_DOMAIN=?