# ==========================================
# CẤU HÌNH DOCKER COMPOSE 
# ==========================================

# Chế độ chạy: development hoặc production
NODE_ENV=development

# --- CƠ SỞ DỮ LIỆU ---
# Local Docker: dùng cổng 5432
# Supabase từ xa: bỏ comment POSTGRES_HOST và đổi cổng thành 6543
# POSTGRES_HOST=aws-0-ap-southeast-1.pooler.supabase.com
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-database-password

# --- TÀI KHOẢN ADMIN MẶC ĐỊNH ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-admin-password
ADMIN_NAME=Administrator

# --- BẢO MẬT ---
# Khóa bí mật JWT (Đổi thành chuỗi ngẫu nhiên >= 64 ký tự trên production)
JWT_SECRET=your-super-secret-jwt-key-replace-me

# --- CỔNG & CORS ---
BACKEND_PORT=3000
FRONTEND_PORT=5173

# --- PRODUCTION CONFIG ---
# Khi triển khai lên production, bạn có thể cần cấu hình thêm các biến môi trường như
BACKEND_HOST=your-production-backend-domain.com
FRONTEND_HOST=your-production-frontend-domain.com
FRONTEND_PORT=80
NGINX_PORT=80
API_DOMAIN=?
WEB_DOMAIN=?
CORS_ORIGIN=? 
